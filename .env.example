# Copy to .env and fill in. Used by docker-compose.yml.

# REQUIRED: absolute path to the git repo you want the agent to edit.
WORKSPACE=/absolute/path/to/your/repo

# Claude Code authentication — choose ONE:
#  (a) Use your Claude subscription (Pro/Max). Run `claude setup-token` on your host
#      and paste the long-lived token here. No API billing.
CLAUDE_CODE_OAUTH_TOKEN=
#  (b) Use API billing instead. If both are set, the API key takes precedence.
ANTHROPIC_API_KEY=

# GitHub token for branch push + PR creation (needs `repo` scope).
GITHUB_TOKEN=

# Optional overrides.
# AGENTBRIDGE_PORT=8000
# AGENTBRIDGE_AGENT=claude-code
# Where branch worktrees are created. In Docker this defaults to the /worktrees volume
# (see docker-compose.yml); for a direct run it defaults to a folder beside your repo.
# AGENTBRIDGE_WORKTREE_DIR=/worktrees
# Where chat history is stored. Docker uses the /state volume; a direct run defaults to
# ~/.agentbridge (namespaced per workspace).
# AGENTBRIDGE_STATE_DIR=/state
# Which Claude Code settings to load from disk (comma-separated: user,project,local).
# Default loads the workspace's .claude/.mcp.json/CLAUDE.md plus your user settings.
# Set to e.g. "project,local" to ignore global user settings, or empty for the CLI default.
# AGENTBRIDGE_CLAUDE_SETTING_SOURCES=user,project,local
